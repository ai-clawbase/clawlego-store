# reindex.risor — /index 的确定性实现(clawfn 脚本,免 LLM,零 token)。
#
# 读 .llm/entities/transaction(唯一真相),按业务月聚合收入/支出/净额/分类,
# 写派生层 .llm/index/{monthly.json,_index.json},并用最新聚合刷新工作台
# 总览/报表两页(保留预算/账户页)。派生层与实体冲突时一律以实体为准 —— 这正是
# 把账本聚合从"逐 token 让模型现算"换成代码现算的意义:永不漂移。
#
# 只能调 ctx.*(entity/space/ui),拿不到裸 os/exec/net —— 见 _design/clawfn.md §9。

# --- 纯辅助函数(必须先定义后使用;Risor 不做提升) ---

# 跨币种:有 fx.base_amount 用之(已换算到本位币),否则用原 amount。
func base_amount(t) {
  a := t.get("amount")
  base := a == nil ? 0.0 : a
  fx := t.get("fx")
  ba := fx == nil ? nil : fx.get("base_amount")
  ba == nil ? base : ba
}

func month_of(t) {
  d := t.get("date")
  (d == nil || len(d) < 7) ? "" : d[:7]
}

# 计入统计吗?(排除作废/冲正/转账/调整/无月份)
func counts(t, voided) {
  ok := true
  if t.get("status") == "void" { ok = false }
  id := t.get("id")
  if id != nil && voided.get(id) != nil { ok = false }
  if t.get("void_of") != nil { ok = false }
  ty := t.get("type")
  if ty == "transfer" || ty == "adjust" { ok = false }
  if month_of(t) == "" { ok = false }
  ok
}

# 按 map 的值降序返回键列表(分类很少,选择排序足够)。
func sort_by_value_desc(m) {
  ks := keys(m)
  out := []
  used := {}
  n := len(ks)
  i := 0
  for i < n {
    best := nil
    bestv := 0.0
    found := false
    for j, k := range ks {
      if used.get(k) != nil { continue }
      v := m[k]
      if !found || v > bestv {
        found = true
        bestv = v
        best = k
      }
    }
    if best != nil {
      used[best] = true
      out.append(best)
    }
    i = i + 1
  }
  out
}

func report_columns() {
  [
    {"key": "category", "label": "分类"},
    {"key": "amount", "label": "金额"},
    {"key": "ratio", "label": "占比"},
  ]
}

# 在组件列表里找到 id==cid 的组件,设置其 props[key]=value(非破坏性刷新)。
func set_props(comps, cid, key, value) {
  for i, c := range comps {
    if c.get("id") == cid {
      p := c.get("props")
      if p == nil {
        p = {}
        c["props"] = p
      }
      p[key] = value
    }
  }
}

# 确保账户在余额表里存在(账目引用了 accounts.json 未登记的账户时兜底)。
func ensure_acct(bal, meta, aid) {
  if aid != nil && bal.get(aid) == nil {
    bal[aid] = 0.0
    meta[aid] = {"name": aid, "type": ""}
  }
}

# --- 主流程 ---

base_ccy := ctx.fields.get("currency", "CNY")
txns := ctx.entity.query("transaction")

# 冲正:status=void 的行,以及被某条 void_of 指向的原行,统计时一并对消。
voided := {}
for i, t := range txns {
  vo := t.get("void_of")
  if vo != nil {
    voided[vo] = true
  }
}

months := {}
for i, t := range txns {
  if !counts(t, voided) { continue }
  mo := month_of(t)
  b := months.get(mo)
  if b == nil {
    b = {"income": 0.0, "expense": 0.0, "net": 0.0, "count": 0, "by_category": {}}
    months[mo] = b
  }
  amt := base_amount(t)
  b["count"] = b["count"] + 1
  ty := t.get("type")
  if ty == "income" {
    b["income"] = b["income"] + amt
  } else {
    b["expense"] = b["expense"] + amt
    cat := t.get("category")
    ck := cat == nil ? "未分类" : cat
    bc := b["by_category"]
    bc[ck] = bc.get(ck, 0.0) + amt
  }
}

mkeys := keys(months)
latest := ""
for i, mo := range mkeys {
  b := months[mo]
  b["net"] = b["income"] - b["expense"]
  if mo > latest {
    latest = mo
  }
}

# 账户余额:opening_balance + 交易增减(转账两腿都动,作废/冲正不动)。
accts_doc := ctx.space.read_json(".llm/data/accounts.json")
acct_list := []
if accts_doc != nil {
  al := accts_doc.get("accounts")
  if al != nil {
    acct_list = al
  }
}
bal := {}
acct_meta := {}
for i, a := range acct_list {
  aid := a.get("id")
  if aid != nil {
    bal[aid] = a.get("opening_balance", 0.0)
    acct_meta[aid] = {"name": a.get("name", aid), "type": a.get("type", "")}
  }
}
for i, t := range txns {
  if t.get("status") == "void" { continue }
  id := t.get("id")
  if id != nil && voided.get(id) != nil { continue }
  if t.get("void_of") != nil { continue }
  amt := base_amount(t)
  ty := t.get("type")
  acc := t.get("account")
  ensure_acct(bal, acct_meta, acc)
  if ty == "expense" && acc != nil {
    bal[acc] = bal[acc] - amt
  }
  if (ty == "income" || ty == "adjust") && acc != nil {
    bal[acc] = bal[acc] + amt
  }
  if ty == "transfer" {
    toa := t.get("to_account")
    ensure_acct(bal, acct_meta, toa)
    if acc != nil { bal[acc] = bal[acc] - amt }
    if toa != nil { bal[toa] = bal[toa] + amt }
  }
}
net_worth := 0.0
acct_rows := []
for i, aid := range keys(bal) {
  net_worth = net_worth + bal[aid]
  meta := acct_meta.get(aid, {"name": aid, "type": ""})
  acct_rows.append({"name": meta.get("name", aid), "type": meta.get("type", ""), "balance": sprintf("%.2f", bal[aid])})
}
ctx.space.write_json(".llm/index/accounts_balance.json", {
  "as_of": ctx.now(),
  "base_currency": base_ccy,
  "net_worth": net_worth,
  "balances": bal,
})

# 派生层:按月聚合 + 索引头(records_digest 锁实体文件的新鲜度)。
src := ctx.space.read(".llm/entities/transaction/records.jsonl")
digest := ctx.hash(src == nil ? "" : src)
now := ctx.now()
ctx.space.write_json(".llm/index/monthly.json", {
  "base_currency": base_ccy,
  "built_at": now,
  "months": months,
})
ctx.space.write_json(".llm/index/_index.json", {
  "schema_version": "2",
  "data_schema_version": 2,
  "built_at": now,
  "records_digest": digest,
  "txn_count": len(txns),
  "month_count": len(mkeys),
  "latest_month": latest,
})

# 总览口径取最近月。
cur := latest == "" ? {"income": 0.0, "expense": 0.0, "net": 0.0, "count": 0, "by_category": {}} : months[latest]
kpi_stats := [
  {"label": "净资产", "value": sprintf("%.2f", net_worth)},
  {"label": "本月支出", "value": sprintf("%.2f", cur["expense"])},
  {"label": "本月收入", "value": sprintf("%.2f", cur["income"])},
  {"label": "本月结余", "value": sprintf("%.2f", cur["net"])},
]
hint := latest == "" ? "还没有数据。随口记一笔(如「午饭 35」),或拖入账单截图/CSV;然后我会刷新这块总览。" : ("最近账期 " + latest + ",共 " + string(len(mkeys)) + " 个月账目。数据以 .llm/entities/transaction 为准。")

# 报表页:最近月分类支出降序。
report_rows := []
sorted_cats := sort_by_value_desc(cur["by_category"])
for i, ck := range sorted_cats {
  amt := cur["by_category"][ck]
  ratio := cur["expense"] > 0 ? (amt / cur["expense"] * 100.0) : 0.0
  report_rows.append({"category": ck, "amount": sprintf("%.2f", amt), "ratio": sprintf("%.0f%%", ratio)})
}

# 非破坏性刷新:读现有 schema(保留预算/账户页),仅替换总览/报表两页的数据;
# 没有现成 schema 时退回构建一个两页骨架。
schema := ctx.space.read_json(".llm/ui/schema.json")
if schema == nil || schema.get("navigation") == nil {
  schema = {
    "protocol": "clawui",
    "version": "1",
    "navigation": [
      {"id": "overview", "label": "总览", "icon": "carbon:dashboard", "page": {"components": [
        {"id": "kpi", "type": "StatGrid", "props": {"stats": kpi_stats}},
        {"id": "hint", "type": "Markdown", "props": {"content": hint}},
      ]}},
      {"id": "report", "label": "报表", "icon": "carbon:report", "page": {"components": [
        {"id": "by_cat", "type": "Table", "props": {"columns": report_columns(), "rows": report_rows}},
      ]}},
    ],
  }
} else {
  nav := schema["navigation"]
  for i, page := range nav {
    pid := page.get("id")
    pg := page.get("page")
    comps := pg == nil ? nil : pg.get("components")
    if comps == nil {
      continue
    }
    if pid == "overview" {
      set_props(comps, "kpi", "stats", kpi_stats)
      set_props(comps, "hint", "content", hint)
    }
    if pid == "report" {
      set_props(comps, "by_cat", "rows", report_rows)
    }
    if pid == "accounts" {
      set_props(comps, "acc_table", "rows", acct_rows)
    }
  }
}

ctx.ui.emit("workspace", schema)
ctx.space.write_json(".llm/ui/schema.json", schema)
ctx.ok("已重建索引:" + string(len(txns)) + " 笔 / " + string(len(mkeys)) + " 个月;最近账期 " + (latest == "" ? "无" : latest) + "。总览与报表面板已刷新。")
