{
  "title": "AccountBook",
  "description": "账户簿。存为 .llm/data/accounts.json。账户是余额与净值的基础;每笔账目挂在一个 account 上。",
  "schema_version": 2,
  "file": ".llm/data/accounts.json",
  "shape": {
    "schema_version": "int = 2",
    "base_currency": "string,本位币(与实例 fields.currency 一致)",
    "accounts": "Account[]"
  },
  "account_fields": {
    "id": { "type": "string", "required": true, "doc": "acc_ 前缀,小写;稳定不变" },
    "name": { "type": "string", "required": true },
    "type": { "type": "enum", "values": ["cash", "bank", "credit_card", "alipay", "wechat", "prepaid", "investment", "receivable", "other"], "required": true },
    "currency": { "type": "string", "required": true, "default": "本位币" },
    "opening_balance": { "type": "number", "required": false, "default": 0, "doc": "建账初始余额;当前余额 = opening_balance + 该账户全部账目净额" },
    "icon": { "type": "string", "required": false, "doc": "Iconify id,如 carbon:money" },
    "color": { "type": "string", "required": false },
    "order": { "type": "int", "required": false, "doc": "显示排序" },
    "archived": { "type": "bool", "required": false, "default": false, "doc": "停用账户;不参与新入账但保留历史" },
    "credit": { "type": "object", "required": false, "doc": "仅 credit_card:{ \"credit_limit\":number, \"bill_day\":int(1-28), \"repay_day\":int }" }
  },
  "rules": [
    "余额从不直接存,永远由 opening_balance + 账目即时算出(派生),避免漂移。",
    "删除账户=archived:true,不物理删除,否则历史账目悬空。",
    "transfer 同时影响 account(减)与 to_account(增),不计入收支只动账户余额。"
  ],
  "example": {
    "schema_version": 2,
    "base_currency": "CNY",
    "accounts": [
      { "id": "acc_cash", "name": "现金", "type": "cash", "currency": "CNY", "opening_balance": 0, "icon": "carbon:money", "order": 0 },
      { "id": "acc_alipay", "name": "支付宝", "type": "alipay", "currency": "CNY", "opening_balance": 0, "icon": "carbon:logo-alipay", "order": 1 }
    ]
  }
}
