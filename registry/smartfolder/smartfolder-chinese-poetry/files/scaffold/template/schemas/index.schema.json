{
  "title": "Index",
  "description": "诗词索引派生层。存于 .llm/index/ 下各文件。可重建,以 entities/poem 为准。",
  "files": {
    "by_author.json": { "type": "object", "doc": "author_id → poem_id[]" },
    "by_dynasty.json": { "type": "object", "doc": "dynasty → poem_id[]" },
    "by_tag.json": { "type": "object", "doc": "tag → poem_id[]" },
    "by_difficulty.json": { "type": "object", "doc": "difficulty_level → poem_id[]" },
    "recommendations.json": { "type": "object", "doc": "按季节/节气/年龄推荐的诗词候选池" },
    "_meta.json": {
      "fields": {
        "schema_version": { "type": "int" },
        "records_digest": { "type": "string", "doc": "sha256 of records.jsonl for freshness check" },
        "built_at": { "type": "string", "doc": "RFC3339 重建时刻" },
        "stats": { "type": "object", "doc": "统计:poem_count/author_count/dynasty_count" }
      }
    }
  }
}
