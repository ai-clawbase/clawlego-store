{
  "title": "Author",
  "description": "诗人/词人档案。存于 .llm/data/authors.json。",
  "fields": {
    "id": { "type": "string", "required": true, "doc": "唯一标识,如 li-bai" },
    "name": { "type": "string", "required": true, "doc": "姓名" },
    "dynasty": { "type": "string", "required": true, "doc": "朝代" },
    "birth_year": { "type": "int", "required": false, "doc": "生年" },
    "death_year": { "type": "int", "required": false, "doc": "卒年" },
    "biography": { "type": "string", "required": false, "doc": "生平简介" },
    "style": { "type": "string", "required": false, "doc": "风格标签,如 浪漫/现实/婉约/豪放" },
    "representative_works": { "type": "string[]", "required": false, "doc": "代表作诗题列表" },
    "image_url": { "type": "string", "required": false, "doc": "人物画像 URL" },
    "child_friendly": { "type": "bool", "required": false, "default": true, "doc": "是否适合推荐给孩子" },
    "poem_count": { "type": "int", "required": false, "doc": "馆藏作品数量" }
  },
  "example": {
    "id": "li-bai",
    "name": "李白",
    "dynasty": "唐",
    "biography": "字太白,号青莲居士,唐代最伟大的浪漫主义诗人之一,被后人称为'诗仙'。",
    "style": "浪漫",
    "child_friendly": true,
    "poem_count": 986
  }
}
